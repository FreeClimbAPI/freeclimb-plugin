{
  "name": "freeclimb-plugin",
  "version": "0.4.0",
  "private": true,
  "description": "FreeClimb Cursor plugin, shared core, CLI, and standalone MCP monorepo.",
  "license": "MIT",
  "packageManager": "pnpm@11.5.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FreeClimbAPI/freeclimb-plugin.git"
  },
  "scripts": {
    "build": "pnpm --filter @freeclimb/core build && pnpm --filter @freeclimb/mcp build && pnpm --filter freeclimb-cli build",
    "setup": "pnpm install && pnpm build",
    "test": "node --test scripts/test/*.test.mjs && pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "validate": "node scripts/validate-plugin.mjs && node scripts/scan-secrets.mjs",
    "sdk:validate": "node scripts/sdk-matrix.mjs",
    "sdk:test": "node --test scripts/test/*.test.mjs",
    "sdk:drift": "node scripts/check-sdk-drift.mjs",
    "docs:drift": "node scripts/check-docs-drift.mjs"
  },
  "devDependencies": {
    "yaml": "^2.9.0"
  }
}
