{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "hooks/freeclimb-session-start.sh"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "hooks/freeclimb-cli-guard.mjs",
        "matcher": "freeclimb\\s"
      }
    ],
    "afterFileEdit": [
      {
        "command": "hooks/freeclimb-percl-guard.mjs"
      }
    ]
  }
}
